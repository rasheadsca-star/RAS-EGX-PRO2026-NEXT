{
  "schemaVersion": "13.15.0",
  "name": "Stability & Evidence Core",
  "registration": {
    "maximumSignalsPerSession": 20,
    "allowedTiers": [
      "STRICT_PAPER",
      "TIER_A_EXPERIMENTAL_PAPER",
      "TIER_B_PRIORITY_WATCH"
    ],
    "requireSingleAnalysisSession": true,
    "requireValidPlan": true,
    "maximumHardFailureCount": 0,
    "requireStrategyId": true,
    "immutableRegistration": true
  },
  "evaluation": {
    "entryExpirySessions": 5,
    "maximumHoldSessions": 10,
    "sameSessionStopAndTargetRule": "STOP_FIRST",
    "targetUsedForPrimaryOutcome": "TARGET1",
    "timeExitUsesClosingPrice": true,
    "transactionCostR": 0.05
  },
  "activation": {
    "activePaper": {
      "minimumClosedTrades": 30,
      "minimumForwardSessions": 10,
      "minimumProfitFactor": 1.15,
      "minimumAverageR": 0.0,
      "minimumMedianR": 0.0,
      "maximumDrawdownPct": 20.0,
      "riskScale": 0.1
    },
    "activeLimited": {
      "minimumClosedTrades": 50,
      "minimumForwardSessions": 20,
      "minimumProfitFactor": 1.2,
      "minimumAverageR": 0.0,
      "minimumMedianR": 0.0,
      "maximumDrawdownPct": 15.0,
      "riskScale": 0.25
    }
  },
  "safety": {
    "liveExecutionEnabled": false,
    "automaticOrderSubmission": false,
    "activationIsPaperOnly": true,
    "manualStatusOverrideAllowed": false,
    "backfillMayNotCreateActiveStatus": false
  }
}
